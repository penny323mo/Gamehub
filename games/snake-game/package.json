    "dev": "vite",
    "build": "tsc -b && vite build && node -e \"const fs=require('fs'),p='dist/index.html';let h=fs.readFileSync(p,'utf8');h=h.replace(/ type=\\\"module\\\" crossorigin/g,'').replace(/(<script) src=/g,'$1 defer src=').replace(/ crossorigin/g,'');fs.writeFileSync(p,h);\"",
